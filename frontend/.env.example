# Copy to .env.local (never commit .env.local). Auth0 is optional; for Render, set secrets in the dashboard with your *.onrender.com URLs.

# Browser calls Flask directly so the session cookie (set on the API host after OAuth) is sent.
# Local: point at Flask. Production (separate Render services): set to the backend public URL.
# Note: Docker `next build` often runs without this var; `app/layout.tsx` injects it at runtime from
# NEXT_PUBLIC_API_URL or BACKEND_PUBLIC_URL so Render dashboard env still works without build-time secrets.
NEXT_PUBLIC_API_URL=http://localhost:5001

# Server-side proxy to Flask (Docker Compose)
BACKEND_URL=http://backend:5001

# Optional public URL
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional Auth0 — configure in Render with production callback URLs; do not commit real secrets.
# AUTH0_SECRET=
# AUTH0_BASE_URL=http://localhost:3000
# AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
# AUTH0_CLIENT_ID=
# AUTH0_CLIENT_SECRET=
# AUTH0_AUDIENCE=
