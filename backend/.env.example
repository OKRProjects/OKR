# Copy to .env (never commit .env). Auth0 is required unless ALLOW_INSECURE_AUTH0_DEV=1 on a non-production Flask env.

FLASK_ENV=development
FLASK_SECRET_KEY=change-me-use-openssl-rand-hex-32
PORT=5001

MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster.example.mongodb.net/?appName=Cluster0
MONGODB_DB_NAME=okrprojects

# Local Postgres (docker-compose default database name is okr)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/okr
OKR_REPOSITORY=postgres

FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:5001
CORS_ORIGINS=http://localhost:3000

# Auth0 (required in production). For local dev without a tenant, set ALLOW_INSECURE_AUTH0_DEV=1 (never with FLASK_ENV=production).
# ALLOW_INSECURE_AUTH0_DEV=1
# Optional synthetic user when using ALLOW_INSECURE_AUTH0_DEV:
# AUTH_DISABLED_USER_ID=auth0|demo_u1
# AUTH_DISABLED_USER_NAME=Sarah Chen
# AUTH_DISABLED_USER_EMAIL=sarah@company.com

AUTH0_ISSUER_BASE_URL=https://YOUR_TENANT.us.auth0.com
AUTH0_CLIENT_ID=
AUTH0_CLIENT_SECRET=
# AUTH0_AUDIENCE=
# AUTH0_DOMAIN=YOUR_TENANT.us.auth0.com

APP_ADMIN_EMAILS=
APP_ADMIN_USER_IDS=
# Comma-separated; these emails get org_owner on login (Mongo synced). Admin bootstrap wins if the same email is in both lists.
APP_ORG_OWNER_EMAILS=
# Display name for the auto-created Postgres organization (sidebar “Hierarchy”). Also renames existing *'s organization names on GET /orgs.
APP_DEFAULT_ORG_NAME=

# Optional integrations (set in Render as secrets)
# CLOUDINARY_CLOUD_NAME= CLOUDINARY_API_KEY= CLOUDINARY_API_SECRET=
# OPENAI_API_KEY= OPENROUTER_API_KEY=
# GOOGLE_CLIENT_ID= GOOGLE_CLIENT_SECRET= GOOGLE_REDIRECT_URI=
# INTEGRATIONS_TOKEN_KEY=
